# Variables de entorno del Sistema Médico Web
# Copia este archivo a .env y ajusta los valores

# Entorno
NODE_ENV=development
PORT=3000
FRONTEND_PORT=8080

# Base de datos Oracle
DB_USER=sistema_medico
DB_PASSWORD=tu_password_seguro
DB_CONNECTION_STRING=localhost:1521/XEPDB1
# Formato alternativo: DB_CONNECTION_STRING=//hostname:port/service_name
# Para Oracle Cloud: DB_CONNECTION_STRING=(description=(address=(protocol=tcps)(port=1522)(host=xxx.oraclecloud.com))(connect_data=(service_name=xxx_high.adb.oraclecloud.com))(security=(ssl_server_cert_dn="CN=xxx")))

# Pool de conexiones Oracle
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_INCREMENT=1
DB_POOL_TIMEOUT=60
DB_QUEUE_TIMEOUT=60000

# JWT (cambia en producción)
JWT_SECRET=secreto_medico_2024_super_seguro
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET=refresh_secreto_medico_2024
REFRESH_TOKEN_EXPIRES_IN=7d

# Email (opcional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=tu-email@gmail.com
EMAIL_PASS=tu-contraseña-o-app-password

# Configuración del sistema
APP_NAME=Sistema Médico Web
APP_VERSION=1.0.0
COMPANY_NAME=Centro Médico Salud Integral

# Seguridad
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=5

# Logs
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Archivos (uploads)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# Backup
BACKUP_DIR=./backups
AUTO_BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *

# Moneda y configuración regional
DEFAULT_CURRENCY=BOB
TIMEZONE=America/La_Paz
DATE_FORMAT=YYYY-MM-DD
TIME_FORMAT=HH:mm:ss

# API externas (opcional)
WEATHER_API_KEY=
GOOGLE_MAPS_API_KEY=